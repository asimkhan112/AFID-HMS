# Copy this file to .env and fill in your values
# ── Database ──────────────────────────────────────────────────────────────────
# For development (SQLite) - no setup needed:
DATABASE_URL=sqlite:///./afid.db

# For production (PostgreSQL) - uncomment and update with your credentials:
# DATABASE_URL=postgresql://afid_user:afid_pass@localhost:5432/afid_db

# ── JWT ───────────────────────────────────────────────────────────────────────
SECRET_KEY=replace_with_a_long_random_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── CORS ──────────────────────────────────────────────────────────────────────
# Add your frontend URLs here (comma-separated if multiple)
CORS_ORIGINS=["http://localhost","http://127.0.0.1","null","http://localhost:5173","http://localhost:3000","http://localhost:3001","http://localhost:3002"]
